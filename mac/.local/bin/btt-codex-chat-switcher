#!/usr/bin/env zsh
set -euo pipefail

state_dir="${TMPDIR:-/tmp}/btt-codex-chat-switcher"
token_file="$state_dir/latest-token"
log_file="$state_dir/last-run.log"
event_helper="/Users/vp/.local/bin/btt-codex-key-event"
release_delay="${BTT_CODEX_CHAT_SWITCHER_RELEASE_DELAY:-12.0}"
select_click_delay="${BTT_CODEX_CHAT_SWITCHER_SELECT_CLICK_DELAY:-0.001}"

mkdir -p "$state_dir"

log() {
  printf '%s pid=%s %s\n' "$(date '+%Y-%m-%dT%H:%M:%S%z')" "$$" "$*" >> "$log_file"
}

run_event() {
  local command="$1"
  local output

  if ! output="$("$event_helper" "$command" 2>&1)"; then
    log "event-helper failed command=$command output=$output"
    exit 1
  fi
}

release_control() {
  rm -f "$token_file"
  run_event control-up
  log "released control reason=${1:-manual}"
}

case "${1:-open}" in
  open)
    ;;
  release)
    release_control "release-command"
    exit 0
    ;;
  select)
    if [[ -e "$token_file" ]]; then
      sleep "$select_click_delay"
      run_event click-current-position
      log "clicked current pointer position for selection"
    else
      log "select requested without active token"
    fi

    release_control "select-command"
    exit 0
    ;;
  *)
    log "invalid command=${1:-}"
    exit 64
    ;;
esac

if token="$(date +%s%N 2>/dev/null)"; then
  :
else
  token="$(date +%s)-$$-$RANDOM"
fi

printf '%s\n' "$token" > "$token_file"
log "scheduled open-only token=$token delay=$release_delay"

(
  sleep "$release_delay"

  current_token="$(cat "$token_file" 2>/dev/null || true)"
  if [[ "$current_token" == "$token" ]]; then
    release_control "fallback token=$token"
    rm -f "$token_file"
  else
    log "skipped release token=$token current=$current_token"
  fi
) >/dev/null 2>&1 &

run_event control-down
sleep 0.001
run_event tab-with-control
log "opened chat switcher with control-down + tab token=$token"
