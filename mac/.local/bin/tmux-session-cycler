#!/bin/bash
# Visual session cycler for tmux
# Opens a centered overlay, any keypress cycles to next session.
# Auto-closes after 1s of inactivity.

tput civis  # hide cursor
trap 'tput cnorm' EXIT  # restore cursor on exit

tmux switch-client -n

while true; do
    clear
    current=$(tmux display-message -p '#{session_name}')

    printf "\033[1;90m ─ Sessions ─\033[0m\n"

    while IFS= read -r session; do
        if [ "$session" = "$current" ]; then
            printf "\033[1;36m ▸ %s\033[0m\n" "$session"
        else
            printf "\033[90m   %s\033[0m\n" "$session"
        fi
    done < <(tmux list-sessions -F '#{session_name}')

    if ! read -rsn1 -t 1; then
        break
    fi

    tmux switch-client -n
done
