#!/bin/bash
# Flat table picker for tmux sessions/windows/panes

{
    printf "SESSION\tWIN\tNAME\tCMD\tPATH\n"
    tmux list-windows -a -F "#{session_name}\t#{window_index}\t#{window_name}\t#{pane_current_command}\t#{pane_current_path}"
} | \
    column -t -s '	' | \
    fzf --header-lines=1 --reverse --border | \
    sed -E 's/^(.*[^ ])  +([0-9]+)  +.*/\1:\2/' | \
    xargs -I {} tmux switch-client -t {}
